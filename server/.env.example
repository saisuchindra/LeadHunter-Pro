# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/leadhunter

# Google APIs
GOOGLE_PLACES_API_KEY=AIza_YOUR_KEY_HERE
GOOGLE_PAGESPEED_API_KEY=AIza_YOUR_KEY_HERE

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Optional: SendGrid
SENDGRID_API_KEY=SG_YOUR_KEY_HERE

# Rate Limiting
SEARCH_RATE_LIMIT=10
EMAIL_RATE_LIMIT_HOURLY=50

# Redis (for job queues)
REDIS_URL=redis://localhost:6379
